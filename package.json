{
    "name": "knowledge-review-electron",
    "version": "0.1.0",
    "description": "Knowledge management and spaced-review desktop app built with Electron.",
    "main": "src/main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron .",
        "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js",
