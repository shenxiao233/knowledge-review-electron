{
  "name": "knowledge-review-market-api",
  "private": true,
  "version": "0.1.0",
  "description": "Backend API for the Knowledge Review deck market.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:restore-orphan-deck": "tsx src/scripts/restore-orphan-deck.ts --apply",
    "admin:create": "tsx src/scripts/create-admin.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.0.3",
    "adm-zip": "^0.5.16",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "prisma": "^6.3.1",
    "@prisma/client": "^6.3.1",
    "zod": "^3.24.2",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
